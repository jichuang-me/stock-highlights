# Stock Highlights environment template
# Copy this file to `.env` for local development, or set the same keys in Hugging Face Space Secrets.

# Optional AI providers. The app will try them by priority and fall back to rule-based analysis.
DEEPSEEK_API_KEY=your_deepseek_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key
HF_TOKEN=your_huggingface_token

# Optional runtime tuning
REQUEST_TIMEOUT=8
CNINFO_DAYS_DEFAULT=180
CORS_ALLOW_ORIGINS=*
